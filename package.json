{
  "name": "fast-lookup",
  "version": "1.0.0",
  "description": "题目速查系统 - 题库管理与快速查询",
  "author": "Gong Xudong",
  "email": "gongxudong_cs@aliyun.com",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "pack": "vite build && electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "vite build && electron-builder --win --publish always"
  },
  "dependencies": {
    "sql.js": "^1.10.2",
    "vue": "^3.4.21",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "com.fastlookup.app",
    "productName": "题目速查系统",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "GongXudong",
        "repo": "fast_lookup"
      }
    ]
  }
}
